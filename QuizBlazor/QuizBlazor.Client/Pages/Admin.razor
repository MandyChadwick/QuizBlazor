@page "/admin"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using System.Text.Json

<PageTitle>Data Admin</PageTitle>

<style>
    .admin-container {
        max-width: 800px;
        margin: 2rem auto;
    }

    .json-editor {
        font-family: monospace;
        font-size: 1rem;
        background-color: #212529;
        color: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        width: 100%;
        height: 400px;
        border: 2px solid #ced4da;
        resize: vertical;
    }

        .json-editor:focus {
            outline: none;
            border-color: #0d6efd;
        }

    .help-text {
        font-size: 0.95rem;
        color: #6c757d;
        margin-bottom: 1rem;
    }
</style>

<div class="admin-container">
    <h2>Update Question Bank</h2>
    <p class="help-text">
        Paste your custom JSON array below. It must be a valid JSON array containing objects with <strong>Id</strong>, <strong>Question</strong>, and <strong>Answer</strong> properties.
    </p>

    @if (!string.IsNullOrEmpty(feedbackMessage))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success") mb-3">
            @feedbackMessage
        </div>
    }

    <textarea class="json-editor mb-3" @bind="jsonInput"></textarea>

    <div class="d-flex gap-2">
        <button class="btn btn-primary px-4" @onclick="SaveCustomJson">
            Save Custom Data
        </button>
        <button class="btn btn-outline-danger px-4" @onclick="RestoreDefault">
            Restore Default File
        </button>
    </div>
</div>

@code {
    private string jsonInput = "";
    private string feedbackMessage = "";
    private bool isError = false;

    // JSON options to handle case-insensitivity just in case your AI capitalizes properties differently
    private JsonSerializerOptions jsonOptions = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };

    protected override async Task OnInitializedAsync()
    {
        // When the page loads, check if we have custom data saved. If not, load the default file so they have a template.
        var existingCustomData = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "customQuestions");

        if (!string.IsNullOrWhiteSpace(existingCustomData))
        {
            jsonInput = existingCustomData;
        }
        else
        {
            jsonInput = await Http.GetStringAsync("data/questions.json");
        }
    }

    private async Task SaveCustomJson()
    {
        try
        {
            // 1. Attempt to parse the text to ensure it's valid JSON and matches your structure
            var testParse = JsonSerializer.Deserialize<List<QAPair>>(jsonInput, jsonOptions);

            if (testParse == null || !testParse.Any())
            {
                throw new Exception("The JSON array is empty or formatted incorrectly.");
            }

            // 2. If it parses successfully, save it to the browser's local storage
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "customQuestions", jsonInput);

            feedbackMessage = $"Successfully saved {testParse.Count} items! Your games will now use this data.";
            isError = false;
        }
        catch (JsonException ex)
        {
            feedbackMessage = "JSON Syntax Error: Make sure you aren't missing any quotes, commas, or brackets. (" + ex.Message + ")";
            isError = true;
        }
        catch (Exception ex)
        {
            feedbackMessage = "Error: " + ex.Message;
            isError = true;
        }
    }

    private async Task RestoreDefault()
    {
        // Clear local storage and reload the default file
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "customQuestions");
        jsonInput = await Http.GetStringAsync("data/questions.json");

        feedbackMessage = "Custom data cleared. Games will now use the default questions.json file.";
        isError = false;
    }

    public class QAPair
    {
        public int Id { get; set; }
        public string Question { get; set; }
        public string Answer { get; set; }
    }
}