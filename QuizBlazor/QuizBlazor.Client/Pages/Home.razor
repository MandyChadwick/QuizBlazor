@page "/"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@using System.Text.Json

<PageTitle>Matching Game</PageTitle>

<h1>Q&A Matching Game</h1>

<style>
    /* Layout for Questions on Left, Answers on Right */
    .game-board {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        gap: 2rem;
        margin-top: 2rem;
    }

    .column {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    /* Base styling for the buttons/cards */
    .card {
        padding: 1rem;
        border: 2px solid #ced4da;
        border-radius: 8px;
        background-color: #ffffff;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.2s ease-in-out;
        text-align: center;
        width: 100%;
    }

        .card:hover:not(:disabled) {
            background-color: #f8f9fa;
            border-color: #adb5bd;
        }

        /* Selected state: Blue border as requested */
        .card.selected {
            border: 3px solid #0d6efd; /* Strong blue */
            background-color: #e7f1ff; /* Light blue tint so it stands out */
            font-weight: bold;
        }
</style>

@if (qaPairs == null)
{
    <p><em>Loading game data...</em></p>
}
/* Updated win condition: check if we matched the number of items currently in play */
else if (shuffledQuestions.Count > 0 && matchedIds.Count == shuffledQuestions.Count)
{
    <div class="alert alert-success mt-4">
        <h2>You win! 🎉</h2>
        <button class="btn btn-primary mt-2" @onclick="RestartGame">Play Again</button>
    </div>
}
else
{
    <div class="game-board">
        <div class="column">
            <h3 class="text-center">Questions</h3>
            @foreach (var q in shuffledQuestions)
            {
                // Only render the button if it hasn't been matched yet
                @if (!matchedIds.Contains(q.Id))
                {
                    <button class="card @GetQuestionClass(q)"
                            @onclick="() => SelectQuestion(q)">
                        @q.Question
                    </button>
                }
            }
        </div>

        <div class="column">
            <h3 class="text-center">Answers</h3>
            @foreach (var a in shuffledAnswers)
            {
                // Only render the button if it hasn't been matched yet
                @if (!matchedIds.Contains(a.Id))
                {
                    <button class="card @GetAnswerClass(a)"
                            @onclick="() => SelectAnswer(a)">
                        @a.Answer
                    </button>
                }
            }
        </div>
    </div>
}

@code {
    private List<QAPair> qaPairs;
    private List<QAPair> shuffledQuestions = new();
    private List<QAPair> shuffledAnswers = new();

    private QAPair selectedQuestion;
    private QAPair selectedAnswer;
    private HashSet<int> matchedIds = new();

    // The number of items to show per round
    private int itemsPerRound = 6;

    // Runs when the page first loads
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Only run this the very first time the page loads in the browser
        if (firstRender)
        {
            await LoadData();
            StateHasChanged(); // Tell Blazor to refresh the UI now that data is loaded
        }
    }

    private async Task LoadData()
    {
        // Now it's safe to call JSRuntime!
        var customJson = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "customQuestions");

        if (!string.IsNullOrWhiteSpace(customJson))
        {
            qaPairs = JsonSerializer.Deserialize<List<QAPair>>(customJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        else
        {
            qaPairs = await Http.GetFromJsonAsync<List<QAPair>>("data/questions.json");
        }

        RestartGame();
    }

    private void RestartGame()
    {
        if (qaPairs != null && qaPairs.Any())
        {
            matchedIds.Clear();
            selectedQuestion = null;
            selectedAnswer = null;

            // 1. Pick a random subset of 6 questions from the master list
            var currentRoundPairs = qaPairs.OrderBy(x => Guid.NewGuid()).Take(itemsPerRound).ToList();

            // 2. Shuffle those specific 6 questions and answers independently
            shuffledQuestions = currentRoundPairs.OrderBy(x => Guid.NewGuid()).ToList();
            shuffledAnswers = currentRoundPairs.OrderBy(x => Guid.NewGuid()).ToList();
        }
    }

    private void SelectQuestion(QAPair q)
    {
        selectedQuestion = q;
        _ = CheckMatch();
    }

    private void SelectAnswer(QAPair a)
    {
        selectedAnswer = a;
        _ = CheckMatch();
    }

    private async Task CheckMatch()
    {
        // Only check if both a question and an answer are currently selected
        if (selectedQuestion != null && selectedAnswer != null)
        {
            if (selectedQuestion.Id == selectedAnswer.Id)
            {
                // It's a match!
                matchedIds.Add(selectedQuestion.Id);
                selectedQuestion = null;
                selectedAnswer = null;
            }
            else
            {
                // Not a match. Force the UI to update so the user sees both selections...
                StateHasChanged();

                // ...wait for a brief moment so they can realize it was wrong...
                await Task.Delay(800);

                // ...then reset the selections.
                selectedQuestion = null;
                selectedAnswer = null;
            }
        }
    }

    // Helpers to apply CSS classes based on the card's state
    private string GetQuestionClass(QAPair q)
    {
        if (selectedQuestion == q) return "selected";
        return "";
    }

    private string GetAnswerClass(QAPair a)
    {
        if (selectedAnswer == a) return "selected";
        return "";
    }

    // The C# class representing your JSON structure
    public class QAPair
    {
        public int Id { get; set; }
        public string Question { get; set; }
        public string Answer { get; set; }
    }
}