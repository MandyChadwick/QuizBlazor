@page "/hangman"
@inject HttpClient Http

<PageTitle>Word Guesser</PageTitle>

<style>
    .hangman-container {
        max-width: 800px;
        margin: 1rem auto;
        text-align: center;
    }

    .clue-box {
        background-color: #f8f9fa;
        border: 2px solid #ced4da;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        font-size: 1.25rem;
        font-weight: bold;
        color: #495057;
    }

    /* Word Display */
    .word-display {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        min-height: 60px;
    }

    .letter-box {
        width: 40px;
        height: 50px;
        font-size: 2rem;
        font-weight: bold;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 4px solid #212529;
        color: #212529;
    }

        .letter-box.space {
            border-bottom: none;
            width: 20px;
        }

        .letter-box.revealed-loss {
            color: #dc3545; /* Red color for letters they missed when they lose */
        }

    /* Keyboard */
    .keyboard {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .key-btn {
        width: 45px;
        height: 50px;
        font-size: 1.25rem;
        font-weight: bold;
        border: 2px solid #ced4da;
        border-radius: 8px;
        background-color: #ffffff;
        cursor: pointer;
        transition: all 0.1s;
    }

        .key-btn:hover:not(:disabled) {
            background-color: #e9ecef;
        }

        .key-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .key-btn.correct {
            background-color: #d1e7dd;
            border-color: #198754;
            color: #0f5132;
            opacity: 1;
        }

        .key-btn.incorrect {
            background-color: #f8d7da;
            border-color: #dc3545;
            color: #842029;
            opacity: 0.6;
        }

    /* Lives Tracker */
    .lives-tracker {
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 1.5rem;
    }

        .lives-tracker span {
            color: #dc3545; /* Red for hearts */
        }
</style>

<div class="hangman-container">
    <h2 class="mb-4">Word Guesser</h2>

    @if (qaPairs == null)
    {
        <p><em>Loading game data...</em></p>
    }
    else if (currentQuestion != null)
    {
        <div class="clue-box shadow-sm">
            @currentQuestion.Question
        </div>

        <div class="lives-tracker">
            Lives:
            <span>
                @for (int i = 0; i < livesRemaining; i++)
                {
                    <text>❤ </text>
                }
            </span>
            @if (livesRemaining == 0)
            {
                <span class="text-danger"> 💀</span>
            }
        </div>

        <div class="word-display">
            @foreach (var c in currentAnswerUpper)
            {
                if (c == ' ')
                {
                    <div class="letter-box space"></div>
                }
                else if (!char.IsLetterOrDigit(c))
                {
                    <div class="letter-box">@c</div>
                }
                else if (guessedLetters.Contains(c))
                {
                    <div class="letter-box">@c</div>
                }
                else if (gameState == GameState.Lost)
                {
                    <div class="letter-box revealed-loss">@c</div>
                }
                else
                {
                    <div class="letter-box"></div>
                }
            }
        </div>

        @if (gameState == GameState.Won)
        {
            <div class="alert alert-success mt-4">
                <h3>You got it! 🎉</h3>
                <button class="btn btn-primary mt-3" @onclick="LoadNextQuestion">Play Again</button>
            </div>
        }
        else if (gameState == GameState.Lost)
        {
            <div class="alert alert-danger mt-4">
                <h3>Game Over!</h3>
                <p>The answer was: <strong>@currentQuestion.Answer</strong></p>
                <button class="btn btn-primary mt-3" @onclick="LoadNextQuestion">Try Another Word</button>
            </div>
        }
        else
        {
            <div class="keyboard">
                @foreach (var letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789")
                {
                    <button class="key-btn @GetKeyClass(letter)"
                            @onclick="() => GuessLetter(letter)"
                            disabled="@guessedLetters.Contains(letter)">
                        @letter
                    </button>
                }
            </div>
        }
    }
</div>

@code {
    private List<QAPair> qaPairs;
    private QAPair currentQuestion;
    private string currentAnswerUpper = "";

    // Game State
    private HashSet<char> guessedLetters = new();
    private int maxLives = 6;
    private int livesRemaining;
    private GameState gameState;

    private enum GameState { Playing, Won, Lost }

    protected override async Task OnInitializedAsync()
    {
        qaPairs = await Http.GetFromJsonAsync<List<QAPair>>("data/questions.json");
        LoadNextQuestion();
    }

    private void LoadNextQuestion()
    {
        if (qaPairs != null && qaPairs.Any())
        {
            var random = new Random();
            currentQuestion = qaPairs[random.Next(qaPairs.Count)];
            currentAnswerUpper = currentQuestion.Answer.ToUpper(); // Uppercase for easy comparison

            guessedLetters.Clear();
            livesRemaining = maxLives;
            gameState = GameState.Playing;
        }
    }

    private void GuessLetter(char letter)
    {
        if (gameState != GameState.Playing || guessedLetters.Contains(letter)) return;

        guessedLetters.Add(letter);

        if (!currentAnswerUpper.Contains(letter))
        {
            // Wrong guess
            livesRemaining--;
            if (livesRemaining <= 0)
            {
                gameState = GameState.Lost;
            }
        }
        else
        {
            // Correct guess, check if they won
            CheckWinCondition();
        }
    }

    private void CheckWinCondition()
    {
        bool allLettersFound = true;

        foreach (var c in currentAnswerUpper)
        {
            // Update: We now check if it's a Letter OR a Digit
            if (char.IsLetterOrDigit(c) && !guessedLetters.Contains(c))
            {
                allLettersFound = false;
                break;
            }
        }

        if (allLettersFound)
        {
            gameState = GameState.Won;
        }
    }

    private string GetKeyClass(char letter)
    {
        if (!guessedLetters.Contains(letter)) return "";

        if (currentAnswerUpper.Contains(letter))
            return "correct";

        return "incorrect";
    }

    public class QAPair
    {
        public int Id { get; set; }
        public string Question { get; set; }
        public string Answer { get; set; }
    }
}